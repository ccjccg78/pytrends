[Unit]
Description=Pytrends Streamlit Web UI
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/pytrends-git
ExecStart=/opt/pytrends-git/.venv/bin/streamlit run /opt/pytrends-git/app.py --server.port 8501 --server.address 0.0.0.0
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
